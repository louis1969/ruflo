{
  "name": "@louis1969/ruflo",
  "version": "0.1.0",
  "description": "Self-learning, self-optimizing multi-agent orchestration framework",
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "llm",
    "orchestration",
    "swarm",
    "self-learning",
    "mcp"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ruflo": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core/router": {
      "types": "./dist/core/router/index.d.ts",
      "import": "./dist/core/router/index.js"
    },
    "./core/swarm": {
      "types": "./dist/core/swarm/index.d.ts",
      "import": "./dist/core/swarm/index.js"
    },
    "./core/memory": {
      "types": "./dist/core/memory/index.d.ts",
      "import": "./dist/core/memory/index.js"
    },
    "./core/learning": {
      "types": "./dist/core/learning/index.d.ts",
      "import": "./dist/core/learning/index.js"
    },
    "./core/llm": {
      "types": "./dist/core/llm/index.d.ts",
      "import": "./dist/core/llm/index.js"
    },
    "./core/plugins": {
      "types": "./dist/core/plugins/index.d.ts",
      "import": "./dist/core/plugins/index.js"
    },
    "./core/eval": {
      "types": "./dist/core/eval/index.d.ts",
      "import": "./dist/core/eval/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "npx --yes rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@clack/prompts": "^0.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "openai": "^6.42.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
